    "icons": {
        "16": "images/icon16.png",
        "32": "images/icon32.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
    },
    "permissions": ["favicon", "storage", "history"],
    "homepage_url": "https://github.com/kiss82053917/history-quick-view"
}
