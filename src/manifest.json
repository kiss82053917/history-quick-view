{
    "manifest_version": 3,
    "version": "0.5.0",
    "default_locale": "zh_CN",
    "name": "__MSG_extName__",
    "description": "__MSG_extDesc__",
    "author": "kiss82053917",
    "action": {
        "default_icon": {
            "16": "images/toolbar16.png",
            "32": "images/toolbar32.png"
        },
        "default_popup": "index.html",
        "default_title": "__MSG_extName__"
